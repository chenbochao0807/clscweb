---
import type { GetStaticPaths } from "astro";
import Announcement from "../components/Announcement.astro";
import CalendarEmbed from "../components/CalendarEmbed.astro";
import Pagination from "../components/control/Pagination.astro";
import FeatureCards from "../components/FeatureCards.astro";
import Gallery from "../components/Gallery.astro";
import HeroSection from "../components/HeroSection.astro";
import PostPage from "../components/PostPage.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Statistics from "../components/Statistics.astro";
import ShareButtons from '../../components/ShareButtons.astro';

import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
    const allBlogPosts = await getSortedPosts();
    return paginate(allBlogPosts, {
        pageSize: PAGE_SIZE,
    });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const len = page.data.length;
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? "CLSC 壢中科研" : `最新消息 第 ${page.currentPage} 頁`;
const pageDescription = isFirstPage
    ? "CLSC 壢中科研首頁，整理社團介紹、最新活動、教學資源與研究成果，方便快速認識壢中科研。"
    : `CLSC 壢中科研最新消息第 ${page.currentPage} 頁，瀏覽社團文章、公告與活動紀錄。`;
const breadcrumbs = [{ name: "首頁", url: "/" }];
---

<MainGridLayout title={pageTitle} description={pageDescription} canonical={Astro.url.pathname} breadcrumbs={breadcrumbs}>
    {isFirstPage && (
        <>
            <HeroSection />

            <Announcement />

            <Statistics />

            <FeatureCards />

            <CalendarEmbed />

            <Gallery />

            <SocialLinks />

            <SectionHeader title="最新消息" description="公告、社課紀錄、專題成果與活動文章。" />
        </>
    )}

    <PostPage page={page} />

    <Pagination
        class="mx-auto onload-animation"
        page={page}
        style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
    />

</MainGridLayout>
