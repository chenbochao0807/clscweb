---
import { Icon } from "astro-icon/components";
import SectionHeader from "../components/SectionHeader.astro";
import GitHubStats from "../components/GitHubStats.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const links = [
  {
    label: "Instagram",
    href: "https://www.instagram.com/clsc_17th/",
    icon: "fa6-brands:instagram",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/CLSC.Is.Awesome/",
    icon: "fa6-brands:facebook",
  },
];
---

<MainGridLayout title="加入我們" description="加入壢中科研 CLSC">
  <hr class="my-8 border-[var(--line-divider)]" />

<div>
  <h2 class="text-2xl font-bold mb-6 text-[var(--primary)]">
    GitHub 專案
  </h2>

  <p class="text-[var(--text-muted)] mb-6">
    CLSC 官方網站採用開源方式開發，所有原始碼皆公開於 GitHub，歡迎參與開發、提出建議或回報問題。
  </p>

  <div class="grid gap-4 lg:grid-cols-2">
    <img
      src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQdA_HfB5ORvtzRRhYFTq9JD92wMhnz8z2PgF8eEgEiGA&s=10"
      alt="CLSC GitHub Repository"
      loading="lazy"
      class="w-full rounded-xl"
    />

    <GitHubStats />
  </div>

  <div class="mt-6">
    <a
      href="https://github.com/chenbochao0807/clscweb"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-regular h-11 rounded-xl px-5 font-semibold inline-flex items-center"
    >
      <Icon name="fa6-brands:github" class="mr-2 text-xl" />
      查看 GitHub Repository
    </a>
  </div>
</div>
  <section class="card-base border border-[var(--line-divider)] p-6 md:p-8">
    <SectionHeader title="加入我們" eyebrow="Join CLSC" description="如果你對科學研究、實驗與探索充滿熱情，歡迎加入壢中科研。" />
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-[var(--radius-large)] border border-[var(--line-divider)] p-5">
        <h2 class="text-xl font-bold text-[var(--text-normal)]">社課時間</h2>
        <p class="mt-3 text-[var(--text-muted)]">每週二，實際時間與地點依學校公告及社群訊息為準。</p>
      </article>
      <article class="rounded-[var(--radius-large)] border border-[var(--line-divider)] p-5">
        <h2 class="text-xl font-bold text-[var(--text-normal)]">適合對象</h2>
        <p class="mt-3 text-[var(--text-muted)]">對科學、實驗、研究、程式興趣的同學。</p>
      </article>
    </div>
    <div class="mt-6 flex flex-wrap gap-3">
      {links.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn-regular h-11 rounded-xl px-4 font-semibold">
          <Icon name={link.icon} class="mr-2 text-xl" />
          {link.label}
        </a>
      ))}
    </div>
    
  </section>
</MainGridLayout>
