---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import GitHubRelease from "../components/GitHubRelease.astro";
---

<MainGridLayout
title="下載中心"
description="下載壢中科研相關線上應用、檔案與延伸資源(目前只有app)。"
breadcrumbs={[{ name: "首頁", url: "/" }, { name: "下載中心", url: "/downloads/" }]}
canonical={Astro.url.pathname}
>

<section class="card-base p-8">

<SectionHeader
title="下載中心"
eyebrow="Downloads"
description="CLSC 官方 APP 與相關檔案下載中心。"
/>

<GitHubRelease />

</section>

</MainGridLayout>