---
import Search from "../components/Search.svelte";
import SectionHeader from "../components/SectionHeader.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const breadcrumbs = [
	{ name: "首頁", url: "/" },
	{ name: "站內搜尋", url: "/search/" },
];
---

<MainGridLayout title="站內搜尋" description="搜尋壢中科研的文章、教材、活動與研究紀錄或些許垃圾嘿嘿。" canonical={Astro.url.pathname} breadcrumbs={breadcrumbs} robots="noindex,follow">
	<section class="card-base border border-[var(--line-divider)] p-6 md:p-8">
		<SectionHeader title="站內搜尋" eyebrow="Search" description="輸入Key Word即可搜尋文章、社團介紹、教材與活動紀錄呦。" />
		<div class="rounded-[1.25rem] border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 md:p-6">
			<Search client:load />
		</div>
	</section>
</MainGridLayout>