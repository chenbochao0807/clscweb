---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import Markdown from "./misc/Markdown.astro";

interface Props {
	resources: CollectionEntry<"resources">[];
}

const { resources } = Astro.props;
const renderedResources = await Promise.all(
	resources.map(async (resource) => ({
		resource,
		Content: (await render(resource)).Content,
	})),
);

const categories = [...new Set(resources.map((resource) => resource.data.category))];
const categoryIcons: Record<string, string> = {
	Chemistry: "material-symbols:science",
	Biology: "material-symbols:biotech-rounded",
	Physics: "material-symbols:experiment",
	Competition: "material-symbols:trophy-rounded",
	Slides: "material-symbols:slideshow-rounded",
	GitHub: "fa6-brands:github",
};
---

<div class="space-y-6">
	{categories.map((category) => {
		const items = renderedResources.filter(({ resource }) => resource.data.category === category);
		if (items.length === 0) return null;
		return (
			<section aria-labelledby={`resource-${category}`}>
				<h2 id={`resource-${category}`} class="mb-3 flex items-center gap-2 text-xl font-bold text-[var(--text-normal)]">
					<Icon name={categoryIcons[category] ?? "material-symbols:menu-book-rounded"} class="text-2xl text-[var(--primary)]" />
					{category}
				</h2>
				<div class="grid gap-3 md:grid-cols-2">
					{items.map(({ resource, Content }) => (
						<article class="card-base border border-[var(--line-divider)] p-5">
							<h3 class="text-lg font-bold text-[var(--text-normal)]">{resource.data.title}</h3>
							{resource.data.description && (
								<p class="mt-2 text-sm leading-6 text-[var(--text-muted)]">{resource.data.description}</p>
							)}
							<Markdown class="mt-3 text-sm">
								<Content />
							</Markdown>
							{resource.data.url && (
								<a
									href={resource.data.url}
									target={resource.data.url.startsWith("http") ? "_blank" : undefined}
									rel={resource.data.url.startsWith("http") ? "noopener noreferrer" : undefined}
									class="mt-4 inline-flex items-center text-sm font-semibold text-[var(--primary)]"
								>
									開啟資源
									<Icon name="material-symbols:arrow-forward-rounded" class="ml-1 text-lg" />
								</a>
							)}
						</article>
					))}
				</div>
			</section>
		);
	})}
</div>
