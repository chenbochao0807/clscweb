---
import SectionHeader from "./SectionHeader.astro";

const stats = [
	{ value: "17th", label: "現任幹部" },
	{ value: "40+", label: "社員人數" },
	{ value: "15+", label: "活動紀錄" },
	{ value: "9", label: "幹部人數" },
];
---

<section class="mb-6" aria-labelledby="statistics-title">
	<SectionHeader title="社團概況" />
	<div class="grid grid-cols-2 gap-4 md:grid-cols-4">
		{stats.map((stat) => (
			<div class="card-base border border-[var(--line-divider)] p-6 text-center">
				<div class="text-3xl font-bold text-[var(--primary)]">{stat.value}</div>
				<div class="mt-2 text-sm font-medium text-[var(--text-muted)]">{stat.label}</div>
			</div>
		))}
	</div>
</section>
