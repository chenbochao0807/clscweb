---
import SectionHeader from "./SectionHeader.astro";

interface Props {
	src?: string;
}

const { src = "https://calendar.google.com/calendar/embed?src=zh.taiwan%23holiday%40group.v.calendar.google.com&ctz=Asia%2FTaipei" } =
	Astro.props;
---

<section class="mb-6" aria-labelledby="calendar-title">
	<SectionHeader title="活動行事曆" eyebrow="Calendar" description="社課、活動與重要時程會同步更新。" />
	<div class="card-base border border-[var(--line-divider)] p-3">
		<div class="aspect-[4/3] w-full overflow-hidden rounded-2xl md:aspect-[16/9]">
			<iframe
				title="壢中科研 Google Calendar"
				src={src}
				class="h-full w-full border-0"
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
			></iframe>
		</div>
	</div>
</section>
