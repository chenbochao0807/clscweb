---
import { getCollection, render } from "astro:content";
import MarkdownIt from "markdown-it";

type AnnouncementSource = {
	title: string;
	href?: string;
	body?: string;
	order?: number;
};

type RenderedAnnouncement = AnnouncementSource & {
	content?: Awaited<ReturnType<typeof render>>["Content"];
	bodyHtml?: string;
};

interface Props {
	items?: AnnouncementSource[];
}

const markdown = new MarkdownIt({
	html: false,
	linkify: true,
	breaks: false,
});

const fallbackAnnouncements: AnnouncementSource[] = [
	{
		title: "第 17 屆壢中科研",
		href: "/about/",
		body: "歡迎追蹤最新社團消息，這裡會持續更新社團介紹與活動資訊。",
		order: 1,
	},
	{
		title: "社員招生資訊",
		href: "/join/",
		body: "社員招生資訊將於確認後公告，請留意最新通知。",
		order: 2,
	},
	{
		title: "社課與活動更新",
		href: "/archive/",
		body: "近期社課與活動會持續更新，歡迎到 [文章總覽](/archive/) 查看完整紀錄。",
		order: 3,
	},
	{
		title: "追蹤 Instagram",
		href: "https://www.instagram.com/clsc_17th/",
		body: "追蹤 @[clsc_17th](https://www.instagram.com/clsc_17th/) 獲得即時消息。",
		order: 4,
	},
];

const providedItems = Astro.props.items ?? [];

const collectionItems = providedItems.length === 0
	? (await getCollection("announcements", ({ data }) => {
		return import.meta.env.PROD ? data.draft !== true : true;
	}))
		.sort((a, b) => a.data.order - b.data.order)
		.map(async (entry) => {
			const { Content } = await render(entry);
			return {
				title: entry.data.title,
				href: entry.data.href,
				order: entry.data.order,
				content: Content,
			} satisfies RenderedAnnouncement;
		})
	: [];

const resolvedCollectionItems = collectionItems.length > 0 ? await Promise.all(collectionItems) : [];

const resolvedManualItems = providedItems.map((item) => ({
	...item,
	bodyHtml: item.body ? markdown.renderInline(item.body) : "",
})) satisfies RenderedAnnouncement[];

const resolvedAnnouncements = (resolvedCollectionItems.length > 0
	? resolvedCollectionItems
	: resolvedManualItems.length > 0
		? resolvedManualItems
		: fallbackAnnouncements.map((item) => ({
			...item,
			bodyHtml: item.body ? markdown.renderInline(item.body) : "",
		}))) satisfies RenderedAnnouncement[];

const marqueeAnnouncements = resolvedAnnouncements.concat(resolvedAnnouncements);

function isExternalHref(href?: string) {
	return !!href && /^https?:\/\//i.test(href);
}
---

<section class="announcement" aria-label="最新公告">
	<div class="marquee" role="list">
		{marqueeAnnouncements.map((item) => {
			const itemHref = item.href || "";
			const external = isExternalHref(itemHref);
			const announcementBody = item.bodyHtml || "";

			if (item.content) {
				const Content = item.content;

				return itemHref ? (
					<a
						role="listitem"
						href={itemHref}
						target={external ? "_blank" : null}
						rel={external ? "noopener noreferrer" : null}
						class="announcement-item announcement-link"
					>
						<span class="announcement-title">{item.title}</span>
						<div class="announcement-body"><Content /></div>
					</a>
				) : (
					<article role="listitem" class="announcement-item">
						<span class="announcement-title">{item.title}</span>
						<div class="announcement-body"><Content /></div>
					</article>
				);
			}

			return itemHref ? (
				<a
					role="listitem"
					href={itemHref}
					target={external ? "_blank" : null}
					rel={external ? "noopener noreferrer" : null}
					class="announcement-item announcement-link"
				>
					<span class="announcement-title">{item.title}</span>
					<div class="announcement-body" set:html={announcementBody}></div>
				</a>
			) : (
				<article role="listitem" class="announcement-item">
					<span class="announcement-title">{item.title}</span>
					<div class="announcement-body" set:html={announcementBody}></div>
				</article>
			);
		})}
	</div>
</section>

<style>
.announcement {
	width: 100%;
	overflow: hidden;
	background: var(--card-bg);
	color: var(--text-normal);
	border: 1px solid var(--line-divider);
	border-radius: var(--radius-large);
	margin-bottom: 1.5rem;
	box-shadow: 0 12px 36px rgba(15, 23, 42, 0.08);
}

.marquee {
	display: flex;
	align-items: center;
	gap: 2rem;
	white-space: nowrap;
	padding: 14px 0;
	animation: marquee 30s linear infinite;
	color: var(--text-normal);
	will-change: transform;
}

.announcement:hover .marquee,
.announcement:focus-within .marquee {
	animation-play-state: paused;
}

.announcement-item {
	position: relative;
	display: inline-flex;
	align-items: center;
	gap: 0.75rem;
	flex: 0 0 auto;
	min-width: max-content;
	padding: 0 0 0 1.25rem;
	color: var(--text-normal);
	font-size: 15px;
	font-weight: 600;
	text-decoration: none;
}

.announcement-item::before {
	content: "｜";
	position: absolute;
	left: 0;
	color: color-mix(in srgb, var(--primary) 65%, var(--text-muted));
}

.announcement-title {
	padding: 0.35rem 0.75rem;
	border-radius: 999px;
	background: color-mix(in srgb, var(--primary) 10%, transparent);
	color: var(--primary);
	font-size: 0.8125rem;
	font-weight: 700;
	letter-spacing: 0.02em;
	flex: 0 0 auto;
}

.announcement-body {
	display: inline-flex;
	align-items: center;
	color: var(--text-normal);
	font-weight: 500;
	white-space: nowrap;
}

.announcement-body :global(p) {
	margin: 0;
	display: inline;
}

.announcement-body :global(a) {
	color: var(--primary);
	text-decoration: underline;
	text-underline-offset: 0.15em;
}

.announcement-link:hover .announcement-title,
.announcement-link:focus-visible .announcement-title {
	background: color-mix(in srgb, var(--primary) 18%, transparent);
}

@media (prefers-reduced-motion: reduce) {
	.marquee {
		animation: none;
		overflow-x: auto;
	}
}

@keyframes marquee {
	from {
		transform: translateX(0);
	}
	to {
		transform: translateX(-50%);
	}
}
</style>
