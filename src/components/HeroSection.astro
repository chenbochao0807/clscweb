---
import { Icon } from "astro-icon/components";

const links = [
	{
		label: "加入我們",
		href: "/join/",
		icon: "material-symbols:person-add-rounded",
		primary: true,
	},
	{
		label: "Instagram",
		href: "https://www.instagram.com/_clsc16th_/",
		icon: "fa6-brands:instagram",
		primary: false,
	},
];
---

<section
	class="relative mb-6 overflow-hidden rounded-[var(--radius-large)] border border-[var(--line-divider)] bg-[var(--card-bg)] shadow-[0_24px_70px_rgba(15,23,42,0.12)]"
	aria-labelledby="home-hero-title"
>
	<img
		src="/banner.jpg"
		alt="壢中科研 CLSC 活動橫幅"
		class="absolute inset-0 h-full w-full object-cover"
		loading="eager"
		decoding="async"
	/>
	<div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-950/55 to-sky-950/20"></div>
	<div class="relative min-h-[22rem] px-7 py-12 md:px-10 md:py-16">
		<p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-sky-200">
			Official Website
		</p>
		<h1 id="home-hero-title" class="max-w-3xl text-4xl font-bold leading-tight text-white md:text-6xl">
			壢中科研 CLSC
		</h1>
		<p class="mt-4 text-xl font-medium text-sky-100 md:text-2xl">探索・研究・實驗</p>
		<div class="mt-8 flex flex-wrap gap-3">
			{links.map((link) => (
				<a
					href={link.href}
					target={link.href.startsWith("http") ? "_blank" : undefined}
					rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
					class:list={[
						"inline-flex items-center gap-2 rounded-2xl px-5 py-3 font-semibold transition hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-200",
						link.primary
							? "bg-[var(--primary)] text-slate-950 hover:bg-sky-300"
							: "border border-white/20 bg-white/10 text-white hover:bg-white/20",
					]}
				>
					<Icon name={link.icon} class="text-xl" />
					{link.label}
				</a>
			))}
		</div>
	</div>
</section>
