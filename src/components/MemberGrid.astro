---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import Markdown from "./misc/Markdown.astro";

interface Props {
	members: CollectionEntry<"members">[];
}

const { members } = Astro.props;
const renderedMembers = await Promise.all(
	members.map(async (member) => ({
		member,
		Content: (await render(member)).Content,
	})),
);

const socialLinks = (member: CollectionEntry<"members">) =>
	[
		{ name: "GitHub", href: member.data.github, icon: "fa6-brands:github" },
		{ name: "Instagram", href: member.data.instagram, icon: "fa6-brands:instagram" },
		{ name: "Threads", href: member.data.threads, icon: "fa6-brands:threads" },
	].filter((link) => link.href);
---

<div class="grid gap-4 md:grid-cols-2">
	{renderedMembers.map(({ member, Content }) => (
		<article class="card-base relative border border-[var(--line-divider)] p-6 pr-28">
			<div class="flex gap-5">
				{member.data.photo && (
					<img
						src={member.data.photo}
						alt={`${member.data.name} profile photo`}
						class="absolute right-6 top-6 h-20 w-20 shrink-0 rounded-xl object-cover"
						loading="lazy"
						decoding="async"
					/>
				)}
				<div class="min-w-0">
					<h2 class="flex flex-wrap items-baseline gap-2 text-xl font-bold text-[var(--text-normal)]">
						<span>{member.data.name}</span>
						<span class="text-sm font-semibold text-[var(--primary)]">{member.data.position}</span>
					</h2>
					{member.data.bio && <p class="mt-3 text-sm leading-6 text-[var(--text-muted)]">{member.data.bio}</p>}
				</div>
			</div>
			<Markdown class="mt-5 text-sm">
				<Content />
			</Markdown>
			{socialLinks(member).length > 0 && (
				<div class="mt-5 flex flex-wrap gap-2">
					{socialLinks(member).map((link) => (
						<a
							href={link.href}
							target="_blank"
							rel="noopener noreferrer"
							class="btn-regular h-10 rounded-xl px-3 text-sm font-semibold"
							aria-label={`${member.data.name} ${link.name}`}
						>
							<Icon name={link.icon} class="mr-2 h-5 w-5 shrink-0" aria-hidden="true" />
							{link.name}
						</a>
					))}
				</div>
			)}
		</article>
	))}
</div>
